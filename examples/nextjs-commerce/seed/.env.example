# Copy this file to your Next.js Commerce project as .env.local and adjust values as needed.

# Public browser-side endpoint (mapped by Tyk)
NEXT_PUBLIC_PRICES_API_BASE_URL=http://localhost:8088/commerce/prices

# Optional: Server-side endpoint inside Docker network (if Next.js runs as container in same network)
PRICES_API_BASE_URL=http://tyk-gateway:8080/commerce/prices

# Keycloak (realm imported from ../../idp/keycloak/realm-export.json)
KEYCLOAK_ISSUER_URL=http://localhost:8081/realms/priceprovider
KEYCLOAK_CLIENT_ID=priceprovider-app
