# Database Configuration
# =====================
# For local development with H2 (default - in-memory database)
# No configuration needed, these are the defaults:
# PPS_DB_JDBCURL=jdbc:h2:mem:priceProviderService
# PPS_DB_DRIVER=org.h2.Driver
# PPS_DB_USERNAME=sa
# PPS_DB_PASSWORD=password
# PPS_JPA_DB_PLATFORM=org.hibernate.dialect.H2Dialect

# For local development with PostgreSQL
# Uncomment the following lines to use PostgreSQL instead of H2:
#PPS_DB_JDBCURL=jdbc:postgresql://localhost:5432/priceProviderService
#PPS_DB_DRIVER=org.postgresql.Driver
#PPS_DB_USERNAME=postgres
#PPS_DB_PASSWORD=postgres
#PPS_JPA_DB_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Application Configuration
# =========================
# Data folder for initialization (relative to project root)
# PRICE_PROVIDER_SERVICE_INITIALIZE_DATA_FOLDER=src/main/resources/initialize/

# Sample data import on startup
# PRICE_PROVIDER_SERVICE_INITIALIZE_SAMPLE_DATA_ON=true

# OIDC / OAuth2 Configuration
# ===========================
# Issuer URI of the OIDC provider (Keycloak realm URL)
# Default: http://localhost:8081/realms/priceprovider (local Keycloak dev instance)
# PPS_OIDC_ISSUER_URI=http://localhost:8081/realms/priceprovider

# OAuth2 client ID registered in the IDP for this service (used for resource_access role lookup)
# PPS_OIDC_CLIENT_ID=priceprovider-service

# JWT claim name that holds the user's group paths (e.g. Keycloak "groups")
# PPS_OIDC_GROUPS_CLAIM=groups

# Organization path prefix in group claims
# PPS_OIDC_ORG_PATH_PREFIX=/organizations/

# CORS Configuration
# ==================
# Comma-separated list of allowed origins for CORS requests
# Use * for wildcard (not recommended in production)
# PPS_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Logging Configuration
# =====================
# LOG_FILE_PATH=logs/

# Notes:
# ------
# 1. Copy this file to .env and customize for your local environment
# 2. This file can be used with IntelliJ IDEA's EnvFile plugin
# 3. For Gradle bootRun, source this file before running: source .env && ./gradlew bootRun
# 4. For Docker deployments, use docker-compose.yml or pass environment variables directly
# 5. Never commit sensitive passwords or credentials to version control
