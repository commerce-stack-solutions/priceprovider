<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Price Provider Detailed" id="id-price-provider-detailed" version="4.6.0">
  <folder name="Strategy" id="id-folder-strategy" type="strategy">
    <element xsi:type="archimate:Capability" name="Manage Pricing Strategy" id="id-cap-manage-pricing-strategy"/>
    <element xsi:type="archimate:Resource" name="Agentic Engineering" id="id-res-agentic-engineering"/>
    <element xsi:type="archimate:BusinessProcess" name="Weekly Price Update" id="id-strat-proc-weekly-update"/>
    <element xsi:type="archimate:BusinessProcess" name="Price Import Flow" id="id-strat-proc-import-flow"/>
  </folder>
  <folder name="Business" id="id-folder-business" type="business">
    <element xsi:type="archimate:BusinessService" name="Public Price API" id="id-bus-service-public-api"/>
    <element xsi:type="archimate:BusinessService" name="Protected Price Management API (Admin)" id="id-bus-service-admin-api"/>
    <element xsi:type="archimate:BusinessProcess" name="Update and Publish Prices" id="id-bus-proc-update-prices"/>
    <element xsi:type="archimate:DataObject" name="PriceRow" id="id-bus-data-pricerow"/>
    <element xsi:type="archimate:DataObject" name="Unit" id="id-bus-data-unit"/>
    <element xsi:type="archimate:DataObject" name="Currency" id="id-bus-data-currency"/>
    <element xsi:type="archimate:DataObject" name="TaxClass" id="id-bus-data-taxclass"/>
    <element xsi:type="archimate:DataObject" name="Channel" id="id-bus-data-channel"/>
    <element xsi:type="archimate:DataObject" name="Group" id="id-bus-data-group"/>
    <element xsi:type="archimate:BusinessActor" name="Administrator" id="id-mot-act-admin"/>
    <element xsi:type="archimate:BusinessActor" name="Product Manager" id="id-mot-act-prod-mgr"/>
    <element xsi:type="archimate:BusinessActor" name="Pricing Manager" id="id-mot-act-price-mgr"/>
    <element xsi:type="archimate:BusinessActor" name="Shop System" id="id-mot-act-shop"/>
  </folder>
  <folder name="Application" id="id-folder-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Price Provider Service" id="id-app-comp-service"/>
    <element xsi:type="archimate:ApplicationComponent" name="Price Manager App" id="id-app-comp-manager"/>
    <element xsi:type="archimate:ApplicationComponent" name="Identity Provider (Keycloak)" id="id-app-comp-keycloak"/>
    <element xsi:type="archimate:ApplicationComponent" name="Pricing Tool (External Vendor)" id="id-app-comp-ext-pricing-tool"/>
    <element xsi:type="archimate:ApplicationComponent" name="Instore Kiosk (Flutter)" id="id-app-comp-kiosk"/>
    <element xsi:type="archimate:ApplicationComponent" name="Prometheus" id="id-app-comp-prometheus"/>
    <element xsi:type="archimate:ApplicationComponent" name="Grafana" id="id-app-comp-grafana"/>
    <element xsi:type="archimate:ApplicationComponent" name="Loki" id="id-app-comp-loki"/>
    <element xsi:type="archimate:ApplicationComponent" name="OpenTelemetry" id="id-app-comp-otel"/>
    <element xsi:type="archimate:ApplicationInterface" name="REST API (Public)" id="id-app-iface-public"/>
    <element xsi:type="archimate:ApplicationInterface" name="REST API (Admin)" id="id-app-iface-admin"/>
  </folder>
  <folder name="Technology" id="id-folder-technology" type="technology">
    <element xsi:type="archimate:Node" name="Kubernetes Cluster (Production)" id="id-tech-node-k8s"/>
    <element xsi:type="archimate:Node" name="Customer Kubernetes Cluster" id="id-tech-node-cust-k8s"/>
    <element xsi:type="archimate:SystemSoftware" name="PostgreSQL" id="id-tech-sw-postgres"/>
    <element xsi:type="archimate:SystemSoftware" name="Nginx Ingress Controller" id="id-tech-sw-ingress"/>
    <element xsi:type="archimate:Node" name="Load Balancer" id="id-tech-node-lb"/>
    <element xsi:type="archimate:Artifact" name="Persistent Volume (Locally Redundant)" id="id-tech-art-pv"/>
    <element xsi:type="archimate:Node" name="Priceprovider API Pod" id="id-tech-pod-api"/>
    <element xsi:type="archimate:Node" name="WebApp Pod" id="id-tech-pod-webapp"/>
    <element xsi:type="archimate:Node" name="Keycloak Pod" id="id-tech-pod-keycloak"/>
    <element xsi:type="archimate:Node" name="Database Pod" id="id-tech-pod-db"/>
  </folder>
  <folder name="Motivation" id="id-folder-motivation" type="motivation">
    <element xsi:type="archimate:Driver" name="Large Volume of Price Updates" id="id-mot-driver-volume"/>
    <element xsi:type="archimate:Goal" name="Optimized Import Performance" id="id-mot-goal-imports"/>
    <element xsi:type="archimate:Requirement" name="Availability 99.9%" id="id-mot-req-availability"/>
    <element xsi:type="archimate:Requirement" name="Scalability 5000 req/sec" id="id-mot-req-scalability"/>
    <element xsi:type="archimate:Requirement" name="Performance &lt; 100ms" id="id-mot-req-performance"/>
    <element xsi:type="archimate:Requirement" name="Security OAuth2/OIDC" id="id-mot-req-security"/>
    <element xsi:type="archimate:Requirement" name="Reliability At-least-once" id="id-mot-req-reliability"/>
    <element xsi:type="archimate:Requirement" name="Auditability Change History" id="id-mot-req-audit"/>
    <element xsi:type="archimate:Principle" name="Cloud-Native" id="id-mot-princ-cloud"/>
    <element xsi:type="archimate:Constraint" name="Customer Managed Vendor Tool" id="id-mot-con-ext-tool"/>
  </folder>
  <folder name="Relations" id="id-folder-relations" type="relations">
    <element xsi:type="archimate:RealizationRelationship" id="id-rel-1" source="id-app-comp-service" target="id-bus-service-public-api"/>
    <element xsi:type="archimate:RealizationRelationship" id="id-rel-2" source="id-app-comp-service" target="id-bus-service-admin-api"/>
    <element xsi:type="archimate:AccessRelationship" id="id-rel-3" source="id-app-comp-service" target="id-bus-data-pricerow" accessType="1"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-4" source="id-app-comp-keycloak" target="id-app-comp-service"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-5" source="id-app-comp-keycloak" target="id-app-comp-manager"/>
    <element xsi:type="archimate:AccessRelationship" id="id-rel-6" source="id-mot-act-price-mgr" target="id-app-comp-manager"/>
    <element xsi:type="archimate:AssociationRelationship" id="id-rel-7" source="id-app-comp-manager" target="id-app-comp-keycloak"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-8" source="id-tech-node-k8s" target="id-tech-pod-api"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-9" source="id-tech-node-k8s" target="id-tech-pod-webapp"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-10" source="id-tech-node-lb" target="id-tech-sw-ingress"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-11" source="id-tech-sw-postgres" target="id-app-comp-service"/>
    <element xsi:type="archimate:AssociationRelationship" id="id-rel-12" source="id-app-comp-service" target="id-app-comp-prometheus"/>
    <element xsi:type="archimate:AssociationRelationship" id="id-rel-13" source="id-app-comp-prometheus" target="id-app-comp-grafana"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-14" source="id-app-comp-ext-pricing-tool" target="id-app-iface-admin"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-15" source="id-tech-node-cust-k8s" target="id-app-comp-ext-pricing-tool"/>
    <element xsi:type="archimate:ServingRelationship" id="id-rel-16" source="id-bus-service-public-api" target="id-mot-act-shop"/>
    <element xsi:type="archimate:CompositionRelationship" id="id-rel-17" source="id-app-comp-service" target="id-app-iface-public"/>
    <element xsi:type="archimate:CompositionRelationship" id="id-rel-18" source="id-app-comp-service" target="id-app-iface-admin"/>
    <element xsi:type="archimate:RealizationRelationship" id="id-rel-19" source="id-bus-proc-update-prices" target="id-bus-service-admin-api"/>
    <element xsi:type="archimate:AssociationRelationship" id="id-rel-20" source="id-mot-act-prod-mgr" target="id-strat-proc-weekly-update"/>
  </folder>
  <folder name="Physical" id="id-folder-physical" type="physical"/>
  <folder name="Implementation &amp; Migration" id="id-folder-implementation" type="implementation_migration"/>
  <folder name="Other" id="id-folder-other" type="other"/>
  <folder name="Views" id="id-folder-views" type="diagrams"/>
</archimate:model>
