  "roles": {
    "realm": [
      {
        "name": "priceprovider.admin:Superuser",
        "description": "All permissions including AppPermission management"
      },
      {
        "name": "priceprovider.admin:Admin",
        "description": "Full admin access: read, write, delete all data types in the admin API"
      },
      {
        "name": "priceprovider.admin:Contributor",
        "description": "Contributor: read, write, delete all data types in the admin API"
      },
      {
        "name": "priceprovider.admin:Reader",
        "description": "Reader: read-only access to all data types in the admin API"
      },
      {
        "name": "priceprovider.admin:ChannelContributor",
        "description": "Channel contributor: read, write, delete on channels only"
      },
      {
        "name": "priceprovider.public:PriceRowReader",
        "description": "Public API price reader. Organization filter is derived from the groups claim."
      },
      {
        "name": "priceprovider.public:PriceRowInspector",
        "description": "Public API price inspector. Includes candidate inspection endpoints. Organization filter is derived from the groups claim."
      },
      {
        "name": "priceprovider.admin:GlobalChannelEURContributor",
        "description": "Restricted admin: write & delete EUR prices on global-b2b-sales-channel, read EUR/USD prices"
      }
    ]
  },
